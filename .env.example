# ---- Engramory dev environment (.env) ----
# Copy to .env and fill in. NEVER commit .env.

# Postgres (spine: relational + pgvector + canonical memory)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=engramory
POSTGRES_USER=engramory
POSTGRES_PASSWORD=change_me

# Redis (L1 session cache / events)
REDIS_URL=redis://localhost:6379/0

# MinIO (object storage; S3-compatible — GCS/Blob in cloud)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=engramory
S3_SECRET_KEY=change_me
S3_BUCKET=engramory

# Neo4j (graph engine; enable when graph features are needed).
# NEO4J_USER seeds the container's NEO4J_AUTH; the dev default is 'neo4j'.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# LiteLLM gateway (single OpenAI-compatible endpoint for all models)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=change_me
# Dev uses local Ollama via LiteLLM; cloud points LiteLLM at Vertex/Azure OpenAI.
# OLLAMA_HOST / EMBEDDING_* are recorded app-side; the gateway routing lives in
# config/litellm.config.yaml — keep the two in sync when changing models.
OLLAMA_HOST=http://localhost:11434

# Embeddings (record model + dims so memory can be re-embedded on migration)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMS=768

# Keycloak (identity; Identity Platform / Entra ID in cloud).
# KEYCLOAK_ADMIN / KEYCLOAK_ADMIN_PASSWORD seed the admin account (Keycloak 26+ bootstrap).
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=engramory
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Deployment profile: dev | gcp | azure  (selects adapters)
ENGRAMORY_PROFILE=dev
